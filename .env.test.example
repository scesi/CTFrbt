# Copy to `.env.test` to run the test suite locally:
#   cp .env.test.example .env.test
#   docker compose up -d postgres-test
#   pnpm test
#
# The DATABASE_URL must contain "test" — global-setup refuses to run
# migrations (and the suite refuses to truncate) against any other database.
DATABASE_URL="postgresql://ctfrbt:ctfrbt@localhost:5434/ctfrbt_test"
NEXTAUTH_SECRET="test-secret"
NEXTAUTH_URL="http://localhost:3000"
