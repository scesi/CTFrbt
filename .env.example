# Database — PostgreSQL connection string
DATABASE_URL="postgresql://ctfrbt:ctfrbt@localhost:5432/ctfrbt"

# NextAuth
NEXTAUTH_SECRET="change-this-to-a-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# Rate limiting — defaults sized for a venue where many players share one
# public IP (campus NAT / mobile carrier CGNAT). All optional.
# RATE_LIMIT_IP_MAX=600      # requests per 10s per IP, all /api routes
# RATE_LIMIT_AUTH_MAX=120    # requests per minute per IP on register/login
# LOGIN_LOCKOUT_IP_MAX=60    # failed logins per 15 min per IP before lockout

# Session lifetime in hours — set it to at least the event duration.
# SESSION_MAX_AGE_HOURS=72
